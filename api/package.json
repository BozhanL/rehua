{
  "name": "@rehua/api",
  "version": "0.0.1",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/BozhanL/rehua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BozhanL/rehua.git"
  },
  "bugs": {
    "url": "https://github.com/BozhanL/rehua/issues"
  },
  "private": true,
  "engines": {
    "node": "^24",
    "npm": "^11.11"
  },
  "scripts": {
    "build": "nest build",
    "type": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "dev": "npm run start:dev",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint --max-warnings 0 --fix .",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "npm run test -- --watch",
    "test:cov": "npm run test -- --coverage",
    "test:e2e": "npm run test -- --config ./test/jest.config.ts",
    "check-all:par": "concurrently --kill-others-on-fail npm:type npm:lint npm:test:cov npm:test:e2e npm:format",
    "check-all": "npm run check-all:par -- -m 1",
    "fix-all": "concurrently -m 1 --kill-others-on-fail npm:lint:fix npm:format:fix"
  },
  "dependencies": {
    "@nestia/core": "11.2.1",
    "@nestia/e2e": "11.2.1",
    "@nestia/fetcher": "11.2.1",
    "@nestia/sdk": "11.2.1",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": "11.1.26",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typia": "12.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@nestia/benchmark": "11.2.1",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.26",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.1",
    "@types/supertest": "7.2.0",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-sonarjs": "4.0.3",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "jiti": "2.7.0",
    "nestia": "11.2.1",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.0",
    "ts-node": "10.9.2",
    "ts-patch": "4.0.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  }
}
