{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:disableTypesNodeMajor",
    "helpers:pinGitHubActionDigestsToSemver",
    ":semanticCommits",
    ":timezone(Pacific/Auckland)",

    // ":assignAndReview(BozhanL)", // Add this back when development starts
    ":label(dependencies)",
    ":label({{{manager}}})",

    "local>BozhanL/rehua//.github/renovate/minimumReleaseAge",
    "local>BozhanL/rehua//.github/renovate/automerge"
  ],
  "ignorePresets": ["security:minimumReleaseAgeNpm"],

  "postUpdateOptions": ["npmDedupe", "npmInstallTwice"]
}
