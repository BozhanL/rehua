{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "packageRules": [
    {
      "matchSourceUrls": ["https://github.com/samchon/nestia"],
      "groupName": "nestia monorepo",
      "matchUpdateTypes": ["digest", "patch", "minor", "major"],

      // Must update the patch in the patches folder before update
      "automerge": false,
      "prBodyNotes": [
        "⚠️ **WARNING:** Must update the patch in the patches folder before merge"
      ]
    }
  ]
}
