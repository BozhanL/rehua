{
  "name": "@rehua/sdk",
  "version": "0.0.1",
  "description": "SDK library generated by Nestia",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/BozhanL/rehua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BozhanL/rehua.git"
  },
  "bugs": {
    "url": "https://github.com/BozhanL/rehua/issues"
  },
  "private": true,
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./functional": {
      "default": "./src/functional/index.ts"
    },
    "./functional/*": {
      "default": "./src/functional/*/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:sdk && npm run compile",
    "build:sdk": "rimraf src/functional && cross-env NODE_ENV=nestia npx -w ../api nestia sdk && npm run format:fix -w=false --include-workspace-root",
    "compile": "rimraf lib && tsc",
    "deploy": "npm run build && npm publish"
  },
  "files": [
    "lib",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "cross-env": "10.1.0",
    "rimraf": "6.1.3",
    "ts-patch": "3.3.0",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@nestia/fetcher": "11.3.4",
    "typia": "12.1.1"
  }
}
