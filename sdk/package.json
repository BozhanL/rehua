{
  "name": "@rehua/sdk",
  "version": "0.0.1",
  "description": "SDK library generated by Nestia",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/BozhanL/rehua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BozhanL/rehua.git"
  },
  "bugs": {
    "url": "https://github.com/BozhanL/rehua/issues"
  },
  "private": true,
  "exports": {
    ".": {
      "default": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./functional": {
      "default": "./lib/functional/index.js",
      "types": "./lib/functional/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:sdk && npm run compile",
    "build:sdk": "rimraf src/functional && cd ../api && npx nestia sdk && cd ../sdk",
    "compile": "rimraf lib && tsc",
    "deploy": "npm run build && npm publish",
    "prepare": "ts-patch install"
  },
  "files": [
    "lib",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "rimraf": "6.1.3",
    "ts-patch": "4.0.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@nestia/fetcher": "11.2.1",
    "typia": "12.1.0"
  }
}
