{
  "name": "Node.js & TypeScript & MongoDB",
  "dockerComposeFile": "compose.yaml",
  "service": "app",
  "shutdownAction": "stopCompose",
  "forwardPorts": [3000, 3001, "db:27017"],
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    // Configure properties specific to VS Code.
    "vscode": {
      "extensions": [
        "Orta.vscode-jest",
        "ms-vsliveshare.vsliveshare",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "redhat.vscode-yaml",
        "dbaeumer.vscode-eslint",
        "HTMLHint.vscode-htmlhint",
        "ecmel.vscode-html-css",
        "ms-azuretools.vscode-containers",
        "SonarSource.sonarlint-vscode",
        "oderwat.indent-rainbow",
        "mongodb.mongodb-vscode",
        "github.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "PKief.material-icon-theme"
      ]
    }
  },
  "postCreateCommand": {
    "mongodb_url": "echo 'mongodb://localhost:27017/' > ${containerWorkspaceFolder}/api/mongodb_url.txt",
    "npm": ["npm", "install"]
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/nestjs-cli:2": {},
    "ghcr.io/devcontainers-extra/features/cz-cli:1": {},
    "ghcr.io/devcontainers-extra/features/npm-package:1": {
      "package": "@commitlint/cz-commitlint"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.10.0": {
      "moby": false
    }
  },
  "mounts": [
    {
      "source": "/var/run/docker.sock",
      "target": "/var/run/docker-host.sock",
      "type": "bind"
    }
  ],
  "containerEnv": {
    "MONGODB_URI_FILE": "${containerWorkspaceFolder}/api/mongodb_url.txt"
  },
  "portsAttributes": {
    "3000": {
      "label": "web"
    },
    "3001": {
      "label": "api"
    },
    "27017": {
      "label": "mongodb"
    }
  }
}
