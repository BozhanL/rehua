{
  "name": "rehua",
  "version": "0.0.1",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/BozhanL/rehua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BozhanL/rehua.git"
  },
  "bugs": {
    "url": "https://github.com/BozhanL/rehua/issues"
  },
  "private": true,
  "type": "module",
  "workspaces": [
    "api",
    "web",
    "sdk"
  ],
  "scripts": {
    "commitlint": "commitlint",
    "prepare": "ts-patch install && husky",
    "postinstall": "patch-package",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "patch-package": "8.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/cz-commitlint": "21.0.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "commitizen": "4.3.1",
    "husky": "9.1.7",
    "prettier": "3.8.3"
  }
}
