{
  "name": "rehua",
  "version": "0.0.1",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/BozhanL/rehua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BozhanL/rehua.git"
  },
  "bugs": {
    "url": "https://github.com/BozhanL/rehua/issues"
  },
  "description": "Digital Patient File Storage Enhancement - Ex32 Code",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24",
    "npm": "^11.11"
  },
  "workspaces": [
    "api",
    "web",
    "sdk"
  ],
  "scripts": {
    "commitlint": "commitlint",
    "prepare": "ts-patch install && husky",
    "postinstall": "patch-package",
    "prettier": "prettier --ignore-path .gitignore --ignore-path .prettierignore --ignore-path sdk/.gitignore --ignore-path web/.gitignore --ignore-path api/.gitignore",
    "format": "npm run prettier -- --check .",
    "format:fix": "npm run prettier -- --write . "
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "patch-package": "8.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "husky": "9.1.7",
    "prettier": "3.8.4"
  }
}
